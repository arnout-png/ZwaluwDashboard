# GitHub Personal Access Token (repo read access on arnout-png)
GITHUB_TOKEN=

# Vercel API Token + optional Team ID
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Anthropic API Key (for Claude Haiku summaries)
ANTHROPIC_API_KEY=

# Supabase — maak een nieuw project aan op supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron security — zet dezelfde waarde in Vercel dashboard
CRON_SECRET=vervang-dit-met-een-lang-willekeurig-geheim

# ── Kosten tracking (optioneel) ──────────────────────────────
# Twilio — maandelijkse kosten ophalen via API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Meta — ad spend ophalen via Marketing API
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# Supabase Management API — DB grootte & connecties ophalen
# Haal token op via https://supabase.com/account/tokens
SUPABASE_MGMT_TOKEN=
